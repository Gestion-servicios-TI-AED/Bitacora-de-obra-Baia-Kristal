# Puerto del servidor
PORT=3001

# Base de datos SQLite (dev) o ruta absoluta en producción Docker
DATABASE_URL="file:./dev.db"

# Secreto JWT — cambiar por un valor aleatorio fuerte en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambiar-por-secreto-seguro-en-produccion"

# Directorio de uploads
UPLOAD_DIR="./uploads"

# (Opcional) URL del frontend para CORS. En producción deja en blanco si
# Express sirve el frontend desde el mismo origen.
# CORS_ORIGIN="https://bitacora.tudominio.com"

# Microsoft Graph API — Sincronización de contratistas desde SharePoint
# App registration en Azure AD con permiso: Files.Read.All (Application)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint — Archivo Excel de contratistas
# SHAREPOINT_SITE_URL: URL completa del sitio (ej: https://empresa.sharepoint.com/sites/Obra)
# SHAREPOINT_FILE_PATH: Ruta del archivo relativa a la raíz del drive (ej: /General/Contratistas.xlsx)
# SHAREPOINT_SHEET_NAME: Nombre exacto de la hoja en el Excel
SHAREPOINT_SITE_URL=
SHAREPOINT_FILE_PATH=
SHAREPOINT_SHEET_NAME=