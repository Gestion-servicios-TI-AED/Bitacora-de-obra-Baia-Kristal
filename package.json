{
  "name": "aed-bitacora-obra",
  "version": "1.0.0",
  "private": true,
  "description": "Bitácora de Obra — Constructora AED",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "db:generate": "cd server && npx prisma generate",
    "db:push": "cd server && npx prisma db push",
    "seed": "cd server && npx tsx prisma/seed.ts",
    "setup": "npm run install:all && npm run db:generate && npm run db:push && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "tsx": "^4.22.0",
    "vite": "^8.0.13"
  }
}
